---
import { Image } from 'astro:assets';
import { postImage } from '../lib/images.js';

const { filename, alt, width = 800, height, loading = 'lazy', sizes, class: cls } = Astro.props;
const img = postImage(filename);
---
{img ? (
  <Image src={img} alt={alt} width={width} height={height} sizes={sizes} loading={loading} class={cls} decoding="async" />
) : (
  <div class={cls} style="background:linear-gradient(135deg,var(--surface-2),var(--surface));width:100%;height:100%;"></div>
)}
