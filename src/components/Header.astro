---
import { universWithSlug } from '../lib/site.js';
const univers = universWithSlug();
const nav = [
  { label: 'Classements', href: '/classements/' },
  { label: 'Univers', href: '/univers/' },
  { label: 'À propos', href: '/a-propos/' },
];
const path = Astro.url.pathname;
---
<header class="site-header" data-header>
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label="Acetic — accueil">
      <span class="mark">T5</span>
      <span><b>Acetic</b><span class="dot">.</span></span>
    </a>

    <nav class="nav-main" aria-label="Navigation principale">
      {nav.map((n) => (
        <a href={n.href} aria-current={path.startsWith(n.href) ? 'page' : undefined}>{n.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="/classements/" class="btn btn-ghost">Explorer</a>
      <a href="/classements/" class="btn btn-primary" data-magnetic>
        Voir les TOP 5
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <button class="burger" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="mobileNav">
  <nav>
    {nav.map((n, i) => (
      <a href={n.href}><span class="m-index">0{i + 1}</span>{n.label}</a>
    ))}
    <a href="/"><span class="m-index">00</span>Accueil</a>
  </nav>
</div>
