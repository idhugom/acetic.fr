---
import Base from '../layouts/Base.astro';
import { articles, universWithSlug, SITE } from '../lib/site.js';
const univers = universWithSlug();
const steps = [
  { n: '01', t: 'On sélectionne', d: "On part d'une vraie question : que cherche le lecteur ? On identifie les candidats sérieux, pas les figurants." },
  { n: '02', t: 'On compare', d: 'Critères transparents, tests, retours d’usage et données publiques : chaque candidat passe au même crible.' },
  { n: '03', t: 'On classe', d: 'Du n°5 au n°1, chaque position est justifiée. Pas de classement au doigt mouillé — un raisonnement, à chaque ligne.' },
  { n: '04', t: 'On tranche', d: 'Un verdict clair, un meilleur choix, des alternatives selon votre profil. Vous repartez avec une décision.' },
];
---
<Base seo={{ title: 'À propos', description: "Acetic.fr, le média 100% classements TOP 5 : notre méthode, nos valeurs et notre promesse d’indépendance." }}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow">La maison des palmarès</span>
      <h1>On classe le <span class="text-grad">meilleur</span>,<br/>vous gagnez du temps.</h1>
      <p style="font-size:1.15rem;max-width:60ch;">
        {SITE.name} est né d'un constat simple : trouver « le meilleur » sur internet, c'est perdre des heures entre avis douteux
        et articles interminables. Notre réponse : des <strong>TOP 5</strong> clairs, comparés et argumentés. Rien de plus, rien de moins.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head"><div><span class="eyebrow">Notre méthode</span><h2 class="section-title">Comment on <span class="em">classe</span></h2></div></div>
      <div class="steps" data-reveal-stagger>
        {steps.map((s) => (
          <div class="step">
            <span class="step-n">{s.n}</span>
            <h3>{s.t}</h3>
            <p class="text-dim">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--bg-2);border-block:1px solid var(--border);">
    <div class="wrap">
      <div class="values">
        <div class="val"><span class="val-n" data-count={articles.length}>0</span><span class="val-l">classements publiés</span></div>
        <div class="val"><span class="val-n" data-count={univers.length}>0</span><span class="val-l">univers couverts</span></div>
        <div class="val"><span class="val-n" data-count="100" data-suffix="%">0</span><span class="val-l">indépendance éditoriale</span></div>
        <div class="val"><span class="val-n" data-count="0" data-suffix="€">0</span><span class="val-l">de contenu sponsorisé caché</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap" style="text-align:center;">
      <h2 class="section-title" style="margin-bottom:1.4rem;">Un univers vous appelle ?</h2>
      <a href="/classements/" class="btn btn-primary" data-magnetic>Parcourir les classements <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>
</Base>

<style>
  .steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.2rem; }
  .step { border: 1px solid var(--border); border-radius: var(--radius); padding: 1.6rem; background: var(--surface); }
  .step-n { font-family: var(--font-display); font-size: 2.4rem; color: var(--lime); }
  .step h3 { font-family: var(--font-ui); font-size: 1.2rem; margin-block: .5rem .4rem; }
  .values { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 1.5rem; text-align: center; }
  .val-n { display: block; font-family: var(--font-display); font-size: clamp(2.6rem,7vw,4rem); color: var(--text); line-height: 1; }
  .val-l { font-family: var(--font-ui); font-size: .85rem; color: var(--text-mute); text-transform: uppercase; letter-spacing: .08em; }
</style>
