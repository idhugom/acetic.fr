---
import Base from '../../layouts/Base.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import PostCard from '../../components/PostCard.astro';
import PostImage from '../../components/PostImage.astro';
import { articles, related, readingTime, slugifyUnivers, universMeta, SITE } from '../../lib/site.js';
import { postImage } from '../../lib/images.js';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const c = article.content;
const meta = universMeta(article.univers);
const uSlug = slugifyUnivers(article.univers);
const rt = readingTime(article);
const rel = related(article, 3);
const dateStr = new Date(article.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });

// image absolue pour OG
const imgMeta = postImage(article.image);
const ogImg = imgMeta ? imgMeta.src : undefined;

// TOC
const toc = [];
if (c) {
  if (c.quick_answer) toc.push({ id: 'essentiel', label: "L'essentiel" });
  if (c.comparison?.rows?.length) toc.push({ id: 'comparatif', label: 'Comparatif' });
  (c.items || []).forEach((it) => toc.push({ id: `rang-${it.rank}`, label: it.name, rank: it.rank }));
  if (c.verdict_html) toc.push({ id: 'verdict', label: 'Le verdict' });
  if (c.faq?.length) toc.push({ id: 'faq', label: 'FAQ' });
}

// JSON-LD
const jsonldGraph = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.domain },
      { '@type': 'ListItem', position: 2, name: article.univers, item: `${SITE.domain}/univers/${uSlug}` },
      { '@type': 'ListItem', position: 3, name: article.title, item: `${SITE.domain}/articles/${article.slug}` },
    ],
  },
  {
    '@type': 'Article',
    headline: c?.meta_title || article.title,
    description: c?.meta_description || article.excerpt,
    image: ogImg ? new URL(ogImg, SITE.domain).href : undefined,
    datePublished: article.date,
    dateModified: article.modified,
    author: { '@type': 'Organization', name: SITE.name },
    publisher: { '@type': 'Organization', name: SITE.name, url: SITE.domain },
    mainEntityOfPage: `${SITE.domain}/articles/${article.slug}`,
    articleSection: article.univers,
  },
];
if (c?.items?.length) {
  jsonldGraph.push({
    '@type': 'ItemList',
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    numberOfItems: c.items.length,
    itemListElement: c.items.map((it) => ({ '@type': 'ListItem', position: it.rank, name: it.name })),
  });
}
if (c?.faq?.length) {
  jsonldGraph.push({
    '@type': 'FAQPage',
    mainEntity: c.faq.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer_html.replace(/<[^>]+>/g, '') },
    })),
  });
}
const jsonld = { '@context': 'https://schema.org', '@graph': jsonldGraph };

const seo = {
  title: c?.meta_title || article.title,
  description: c?.meta_description || article.excerpt,
  image: ogImg,
  type: 'article',
  publishedTime: article.date,
  modifiedTime: article.modified,
  jsonld,
};
---
<Base seo={seo} progress={true}>
  <article class="wrap">
    <div class="article-hero">
      <nav class="a-cats" aria-label="Fil d'Ariane">
        <a class="chip" href="/">Accueil</a>
        <a class="chip chip-lime" href={`/univers/${uSlug}`} style={`color:${meta.accent};border-color:color-mix(in srgb,${meta.accent} 40%,transparent)`}>{meta.emoji} {article.univers}</a>
      </nav>
      <h1 class="article-title">{article.title}</h1>
      {c?.hook && <p class="article-hook">{c.hook}</p>}
      <div class="article-meta">
        <span>{dateStr}</span>
        <span class="dotsep">{rt} min de lecture</span>
        <span class="dotsep">Classement vérifié ✓</span>
      </div>
    </div>

    <div class="article-cover" data-reveal>
      <PostImage filename={article.image} alt={article.title} width={1240} height={620} loading="eager" sizes="(max-width:1240px) 100vw, 1240px" />
    </div>

    <div class="article-layout">
      <div>
        <ArticleContent article={article} />
      </div>

      {toc.length > 0 && (
        <aside class="toc-rail">
          <div class="toc-box">
            <h4>Au sommaire</h4>
            {toc.map((t) => (
              <a href={`#${t.id}`} data-toc class="" >
                {t.rank ? <span class="tnum">{t.rank}</span> : <span class="tnum">›</span>}
                <span style="line-height:1.25;">{t.label}</span>
              </a>
            ))}
            <div class="toc-share" aria-label="Partager">
              <a href={`https://twitter.com/intent/tweet?url=${SITE.domain}/articles/${article.slug}`} target="_blank" rel="noopener" aria-label="Partager sur X">𝕏</a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${SITE.domain}/articles/${article.slug}`} target="_blank" rel="noopener" aria-label="Partager sur Facebook">f</a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${SITE.domain}/articles/${article.slug}`} target="_blank" rel="noopener" aria-label="Partager sur LinkedIn">in</a>
            </div>
          </div>
        </aside>
      )}
    </div>
  </article>

  <!-- Related -->
  <section class="section related">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="eyebrow">À lire ensuite</span>
          <h2 class="section-title">Continuez le <span class="em">classement</span></h2>
        </div>
        <a href={`/univers/${uSlug}`} class="btn btn-ghost">Plus de {article.univers}</a>
      </div>
      <div class="cards-grid">
        {rel.map((a) => <PostCard article={a} />)}
      </div>
    </div>
  </section>
</Base>
