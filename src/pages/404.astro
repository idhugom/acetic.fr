---
import Base from '../layouts/Base.astro';
---
<Base seo={{ title: 'Page introuvable' }}>
  <section class="hero" style="min-height:70vh;display:flex;align-items:center;">
    <div class="wrap" style="text-align:center;">
      <div style="font-family:var(--font-display);font-size:clamp(6rem,28vw,20rem);line-height:.8;color:transparent;-webkit-text-stroke:2px var(--lime);">404</div>
      <h1 class="section-title" style="margin-top:1rem;">Ce classement n'existe pas… <span class="em">encore</span></h1>
      <p class="text-dim" style="max-width:46ch;margin:1rem auto 2rem;">La page que vous cherchez a disparu du podium. Revenez à l'essentiel.</p>
      <div style="display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary" data-magnetic>Retour à l'accueil</a>
        <a href="/classements/" class="btn btn-ghost">Voir les classements</a>
      </div>
    </div>
  </section>
</Base>
