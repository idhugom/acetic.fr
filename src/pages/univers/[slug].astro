---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { universWithSlug, articlesByUnivers, universMeta, findUniversBySlug } from '../../lib/site.js';

export function getStaticPaths() {
  return universWithSlug().map((u) => ({ params: { slug: u.slug }, props: { name: u.name } }));
}
const { name } = Astro.props;
const posts = articlesByUnivers(name);
const m = universMeta(name);
---
<Base seo={{ title: `${name} — les classements`, description: `Tous nos classements TOP 5 dans l’univers ${name} : ${posts.length} palmarès comparés, notés et argumentés.` }}>
  <section class="page-hero">
    <div class="wrap">
      <nav class="a-cats" style="margin-bottom:1.2rem;"><a class="chip" href="/univers">← Tous les univers</a></nav>
      <span class="eyebrow" style={`color:${m.accent}`}>{m.emoji} {posts.length} classement{posts.length > 1 ? 's' : ''}</span>
      <h1>{name}</h1>
      <p>Le meilleur de l'univers <strong>{name}</strong>, décrypté en TOP 5. Comparez, tranchez, choisissez.</p>
    </div>
  </section>

  <section class="section" style="padding-top:2rem;">
    <div class="wrap">
      <div class="cards-grid">
        {posts.map((a, i) => <PostCard article={a} rank={i < 5 ? i + 1 : undefined} feature={i === 0} />)}
      </div>
    </div>
  </section>
</Base>
